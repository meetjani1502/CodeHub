generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       Int    @id @default(autoincrement())
  name     String
  email    String @unique
  password String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  repositories Repository[]
}

model Repository {
  id          Int     @id @default(autoincrement())
  name        String
  description String?

  ownerId Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  currentBranchId Int?

  owner User @relation(fields: [ownerId], references: [id])

  branches Branch[] @relation("RepositoryBranches")

  commits      Commit[]
  files        File[]
  pullRequests PullRequest[]

  currentBranch Branch? @relation("CurrentBranch", fields: [currentBranchId], references: [id])
}

model File {
  id       Int    @id @default(autoincrement())
  filename String
  content  String

  repositoryId Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  repository Repository @relation(fields: [repositoryId], references: [id])

  versions FileVersion[]
}

model Commit {
  id      Int    @id @default(autoincrement())
  message String

  repositoryId Int
  branchId     Int?

  createdAt DateTime @default(now())

  repository Repository @relation(fields: [repositoryId], references: [id])
  branch     Branch?    @relation(fields: [branchId], references: [id])

  fileVersions FileVersion[]
}

model FileVersion {
  id Int @id @default(autoincrement())

  fileId   Int
  commitId Int

  filename String
  content  String

  createdAt DateTime @default(now())

  file   File   @relation(fields: [fileId], references: [id])
  commit Commit @relation(fields: [commitId], references: [id])
}

model Branch {
  id Int @id @default(autoincrement())

  name String

  repositoryId Int

  repository Repository @relation("RepositoryBranches", fields: [repositoryId], references: [id])

  commits Commit[]

  sourcePullRequests PullRequest[] @relation("sourceBranch")
  targetPullRequests PullRequest[] @relation("targetBranch")

  currentRepositories Repository[] @relation("CurrentBranch")
}

model PullRequest {
  id          Int     @id @default(autoincrement())
  title       String
  description String?

  status String @default("OPEN")

  repositoryId   Int
  sourceBranchId Int
  targetBranchId Int

  repository Repository @relation(fields: [repositoryId], references: [id])

  sourceBranch Branch @relation("sourceBranch", fields: [sourceBranchId], references: [id])
  targetBranch Branch @relation("targetBranch", fields: [targetBranchId], references: [id])

  createdAt DateTime @default(now())
}
